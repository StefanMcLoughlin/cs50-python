"""
Übung 2 — Passwort mit maximal 3 Versuchen
Aufgabe:

Der Benutzer hat nur 3 Versuche.

Wenn Passwort korrekt:
→ „Zugriff erlaubt“

Wenn 3x falsch:
→ „Konto gesperrt“

Ziel:

Trainiert:

while
Zähler
Bedingungen
Logikfluss
"""

i = 0
while i < 3:
    passwort = input("Bitte Passwort eingeben: ")

    if passwort == "python123":
        print("Zugriff erlaubt")
        break

    else:
        print("Falsches Passwort")
        i += 1

if i == 3:
    print("Konto gesperrt")